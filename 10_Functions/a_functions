def sumNumbers(*values):
  sums = 0
  for i in values:
    sums += i
  print(sums)

# main code
sumNumbers(5,2,3,4)

sumNumbers(9,12,3,6,4,7)

sumNumbers(2,15,87,69,33,22,57,64)

#output:
14
41
349

